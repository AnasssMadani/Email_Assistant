{
  "name": "accuse-reception-relance",
  "version": "0.1.0",
  "private": true,
  "description": "Accuse de reception automatique, brouillons de reponse et relances par email. Phase de test sur Gmail, cible de production Outlook / Microsoft 365.",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc -p .",
    "start": "node dist/index.js",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "gmail:auth": "node ./node_modules/tsx/dist/cli.mjs src/scripts/gmailAuthSetup.ts",
    "test:pipeline": "node ./node_modules/tsx/dist/cli.mjs src/scripts/testPipeline.ts",
    "setup": "node ./node_modules/tsx/dist/cli.mjs src/web/server.ts",
    "dev:all": "node ./node_modules/tsx/dist/cli.mjs src/main.ts",
    "start:all": "node dist/main.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
