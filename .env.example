# Claude API (rediger les accuses de reception, generer les 3 brouillons, classifier)
ANTHROPIC_API_KEY=

# Port de la page de connexion (npm run setup) ou le client choisit
# Gmail ou Outlook et autorise l'acces a sa boite.
WEB_PORT=4300

# Protege la page de connexion et le suivi des dossiers (authentification
# HTTP Basic). Laisser vide UNIQUEMENT en local (localhost) - obligatoire
# des que le service est expose au-dela de votre poste.
SETUP_USERNAME=
SETUP_PASSWORD=

# --- Google Cloud OAuth client (type "Web application") ---
# Console: https://console.cloud.google.com/apis/credentials
# Ajoutez GOOGLE_REDIRECT_URI ci-dessous dans "URI de redirection autorises".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4300/auth/gmail/callback
GOOGLE_TOKEN_PATH=./data/gmail-token.json

# --- Azure AD app registration (Outlook / Microsoft 365) ---
# Portal: https://portal.azure.com -> Azure Active Directory -> App registrations
# Ajoutez AZURE_REDIRECT_URI ci-dessous dans "Redirect URIs" (type Web).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
AZURE_REDIRECT_URI=http://localhost:4300/auth/graph/callback
AZURE_TOKEN_PATH=./data/graph-token.json

# Frequence de scrutation de la boite (format cron)
POLL_INTERVAL_CRON=*/2 * * * *
RELANCE_CHECK_CRON=*/30 * * * *

# Emplacement de la base locale (SQLite, cree automatiquement)
DB_PATH=./data/app.db

# Chemins des fichiers de configuration metier
CATEGORIES_CONFIG_PATH=./config/categories.json
BRAND_VOICE_PATH=./config/brand-voice.md

# Etat de connexion (ecrit automatiquement par la page de connexion,
# ne pas remplir a la main). Determine si le pipeline utilise Gmail ou
# Outlook/Graph. A defaut, EMAIL_CONNECTOR sert de valeur de repli.
CONNECTION_STATE_PATH=./data/connection.json
EMAIL_CONNECTOR=gmail
