# Claude API (rediger les accuses de reception, generer les 3 brouillons, classifier)
ANTHROPIC_API_KEY=

# Port de la page de connexion (npm run setup) ou le client choisit
# Gmail ou Outlook et autorise l'acces a sa boite.
WEB_PORT=4300

# Protege l'application (page de login brandee, session + CSRF). Laisser vide
# UNIQUEMENT en local (localhost) - obligatoire des que le service est expose
# au-dela de votre poste.
SETUP_USERNAME=

# Recommande: hash du mot de passe (pas le mot de passe en clair). Generez-le
# avec: npm run auth:hash-password -- "votre-mot-de-passe"
SETUP_PASSWORD_HASH=

# Deprecie: mot de passe en clair, conserve uniquement pour compatibilite
# ascendante. Si SETUP_PASSWORD_HASH est defini, cette valeur est ignoree.
SETUP_PASSWORD=

# Identifiants du dashboard client (/client/...) - compte separe de l'admin
# ci-dessus. Meme regle: laisser vide UNIQUEMENT en local. Genere avec la
# meme commande: npm run auth:hash-password -- "votre-mot-de-passe"
CLIENT_USERNAME=
CLIENT_PASSWORD_HASH=

# Cle AES-256 (64 caracteres hexadecimaux) pour chiffrer au repos les jetons
# OAuth Gmail/Outlook stockes sur disque. Sans elle, les jetons restent en
# clair (avertissement au demarrage). Generer avec:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Destinataire des rappels internes (email envoye a chaque etape "rappel
# interne" d'une sequence de relance). Laisser vide pour recevoir ces
# notifications dans la messagerie connectee elle-meme.
NOTIFICATION_EMAIL=

# Mode "carnet" (semaine pilote): le pipeline classe et redige normalement,
# mais rien n'est envoye ni depose en brouillon vers le client — tout est
# journalise pour revue (page /carnet). Seul le rappel interne
# (NOTIFICATION_EMAIL ci-dessus) reste un envoi reel. Permanent tant que non
# repasse a false a la main (pas de bascule automatique).
SHADOW_MODE=true

# Delai (en minutes) du rappel interne des 6 categories metier du mode
# carnet. Reglable ici sans toucher au code, applique au prochain
# redemarrage. Ex: 1 pour tester rapidement, 30 en usage reel. IMPORTANT:
# pour qu'un delai court soit realiste, RELANCE_CHECK_CRON ci-dessous doit
# aussi tourner frequemment (ex: */1 * * * *) — sinon le rappel attend le
# prochain cycle de verification, pas seulement le delai configure ici.
CARNET_RAPPEL_DELAY_MINUTES=30

# Dossier des notes de style par categorie generees a partir des vraies
# reponses de l'equipe. Frequence de la passe d'analyse (format cron).
CATEGORY_PLAYBOOKS_DIR=./config/category-playbooks
DAILY_ANALYSIS_CRON=0 3 * * *

# --- Image de marque affichee dans l'application ---
BRAND_NAME=Accusé & Relance
BRAND_PRIMARY_COLOR=#16202A
BRAND_LOGO_URL=

# --- Google Cloud OAuth client (type "Web application") ---
# Console: https://console.cloud.google.com/apis/credentials
# Ajoutez GOOGLE_REDIRECT_URI ci-dessous dans "URI de redirection autorises".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4300/auth/gmail/callback
GOOGLE_TOKEN_PATH=./data/gmail-token.json

# --- Azure AD app registration (Outlook / Microsoft 365) ---
# Portal: https://portal.azure.com -> Azure Active Directory -> App registrations
# Ajoutez AZURE_REDIRECT_URI ci-dessous dans "Redirect URIs" (type Web).
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=common
AZURE_REDIRECT_URI=http://localhost:4300/auth/graph/callback
AZURE_TOKEN_PATH=./data/graph-token.json

# Frequence de scrutation de la boite (format cron)
POLL_INTERVAL_CRON=*/2 * * * *
RELANCE_CHECK_CRON=*/30 * * * *

# Emplacement de la base locale (SQLite, cree automatiquement)
DB_PATH=./data/app.db

# Chemins des fichiers de configuration metier
CATEGORIES_CONFIG_PATH=./config/categories.json
BRAND_VOICE_PATH=./config/brand-voice.md

# Etat de connexion (ecrit automatiquement par la page de connexion,
# ne pas remplir a la main). Determine si le pipeline utilise Gmail ou
# Outlook/Graph. A defaut, EMAIL_CONNECTOR sert de valeur de repli.
CONNECTION_STATE_PATH=./data/connection.json
EMAIL_CONNECTOR=gmail
